# ============================================================
# Server Configuration
# ============================================================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000

# ============================================================
# Data / persistencia
# ============================================================
# Directorio donde viven las bases SQLite. En Docker se monta un volumen aquí.
DATA_DIR=.

# ============================================================
# Autenticación
# ============================================================
# Si es true, se exige token/rol en los endpoints protegidos.
AUTH_ENABLED=false

# ============================================================
# Whisper AI Model (subtítulos)
# ============================================================
# Opciones: tiny, base, small, medium, large ("base" recomendado)
WHISPER_MODEL_SIZE=base

# ============================================================
# TikTok Upload
# ============================================================
# En contenedores debe ser true (no hay display).
TIKTOK_HEADLESS=false

# ============================================================
# Descargas (yt-dlp)
# ============================================================
MAX_DOWNLOAD_RETRIES=3
RETRY_BASE_DELAY=2.0
DOWNLOAD_TIMEOUT=300
# Desactivar verificación TLS (solo si un CDN tiene certificados problemáticos)
YTDLP_INSECURE_SSL=false
# Ruta explícita al ejecutable yt-dlp (si no está en el PATH)
# YTDLP_PATH=

# ============================================================
# Subsistemas opcionales (se inician al arrancar si están en true)
# ============================================================
ENABLE_QUEUE_WORKERS=false
ENABLE_SCHEDULED_BACKUPS=false

# ============================================================
# Servicios externos (opcionales)
# ============================================================
# OPENAI_API_KEY=sk-your-key-here
# REDIS_URL=redis://localhost:6379
